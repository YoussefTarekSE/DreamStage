# DreamStage environment template.
# Copy values into backend/.env, frontend/.env.local, or your deployment secrets.

# Runtime
ENVIRONMENT=development

# Supabase backend credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase migration script
SUPABASE_MANAGEMENT_TOKEN=your-supabase-management-token
SUPABASE_PROJECT_REF=your-supabase-project-ref

# Cloudflare R2 / S3-compatible storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=dreamstage-audio

# AI providers
GROQ_API_KEY=your-groq-api-key
HF_API_KEY=your-huggingface-api-key

# Admin-only backend endpoints
ADMIN_KEY=your-random-admin-bearer-token
ADMIN_USER_IDS=
ADMIN_EMAILS=

# Daily usage limits (0 disables a limit)
DAILY_PROJECT_LIMIT=10
DAILY_BEAT_GENERATION_LIMIT=25
DAILY_MIX_LIMIT=10

# Frontend public Supabase values. These are browser-visible public config.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
